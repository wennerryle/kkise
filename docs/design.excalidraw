      "link": null,
      "locked": false,
      "text": "Requirements for cursor:\n1 When user start recording cursor should move to the current time on the timeline\n2 User can grab cursor and move it across the viewport\n3 Cursor should have red accent color",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Requirements for cursor:\n1 When user start recording cursor should move to the current time on the timeline\n2 User can grab cursor and move it across the viewport\n3 Cursor should have red accent color",
      "autoResize": true,
