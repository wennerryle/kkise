      "isDeleted": false,
      "boundElements": [],
      "updated": 1773227849666,
      "link": null,
      "locked": false,
      "text": "Requirements for viewport:\n1 The viewport should always follow the cursor when recording\n2 When recorder isn't recording user can interact with the timelines\n2.1 User can zoom viewport, and viewport should follow the user cursor when zooming\n2.2 User can move viewport by x-axis\n3 Track Header should always be fixed on viewport on the left side",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Requirements for viewport:\n1 The viewport should always follow the cursor when recording\n2 When recorder isn't recording user can interact with the timelines\n2.1 User can zoom viewport, and viewport should follow the user cursor when zooming\n2.2 User can move viewport by x-axis\n3 Track Header should always be fixed on viewport on the left side",
      "autoResize": true,
      "lineHeight": 1.25
    },
